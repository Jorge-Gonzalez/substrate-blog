---
import Base from '../../layouts/Base.astro'
import { getCollection, render } from 'astro:content'
import { formatDate } from '../../utils/formatDate'
import { useTranslations } from '../../i18n/ui'

export async function getStaticPaths() {
  const posts = await getCollection('postsEn')
  const sorted = posts.filter(p => !p.id.includes('/')).sort((a, b) => {
    if (a.data.seriesPart && b.data.seriesPart) {
      return a.data.seriesPart - b.data.seriesPart
    }
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  })
  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }))
}

const lang = 'en'
const t    = useTranslations(lang)

const { post, prev, next } = Astro.props
const { Content } = await render(post)
---

<Base title={post.data.title} description={post.data.description}>
  <article class="post">

    <header class="post-header">
      {post.data.series && (
        <p class="post-series">
          {post.data.series}
          {post.data.seriesPart && ` — ${t('post.part')} ${post.data.seriesPart}`}
        </p>
      )}
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span>{post.data.topic}</span>
        <span>{formatDate(post.data.date, lang)}</span>
        <span>{post.data.readingTime}</span>
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <section class="comments">
      <h2 class="comments-heading">{t('post.comments')}</h2>
      <div id="remark42"></div>
    </section>

    <footer class="post-footer">
      <div class="post-nav">
        {prev && (
          <a href={`/posts/${prev.id}`} class="post-nav-link prev">
            <span class="post-nav-label">{t('post.previous')}</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
        {next && (
          <a href={`/posts/${next.id}`} class="post-nav-link next">
            <span class="post-nav-label">{t('post.next')}</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
      <a href="/#ideas" class="back-link">{t('post.back')}</a>
    </footer>

  </article>
</Base>

<script>
  function initRemark42() {
    const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'

    // @ts-ignore
    window.remark_config = {
      host:       'https://comments.substrate.lat',
      site_id:    'substrate',
      url:        window.location.href,
      theme:      theme,
      components: ['embed'],
      no_footer:  true,
    }

    const script   = document.createElement('script')
    script.src     = 'https://comments.substrate.lat/web/embed.js'
    script.defer   = true
    document.body.appendChild(script)

    const observer = new MutationObserver(() => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'
      // @ts-ignore
      if (window.REMARK42) window.REMARK42.changeTheme(next)
    })
    observer.observe(document.documentElement, {
      attributes:      true,
      attributeFilter: ['data-theme'],
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRemark42)
  } else {
    initRemark42()
  }
</script>
