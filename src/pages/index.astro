---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { formatDate } from '../utils/formatDate'
import { useTranslations } from '../i18n/ui'

const lang = 'en'
const t    = useTranslations(lang)

const posts  = await getCollection('postsEn')
const sorted = posts.sort((a, b) => {
  if (a.data.seriesPart && b.data.seriesPart) {
    return a.data.seriesPart - b.data.seriesPart
  }
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
})
const featured = sorted[0]
const rest     = sorted.slice(1)
---

<Base title="Substrate">

  <section class="hero" id="home">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-eyebrow">
      <span class="label">Substrate.lat</span>
    </div>
    <h1 class="hero-name">
      Substrate
    </h1>
    <p class="hero-title">Notes on shared ground</p>
    <p class="hero-statement">
      The same underlying structures appear across fields that share no
      obvious reason for them. This site follows that observation — through
      design, mathematics, and philosophy. Not conclusions. Notes.
      <a href="/about" class="hero-about-link">About →</a>
    </p>
    <span class="hero-scroll">Scroll</span>
  </section>

  <section id="ideas">
    <div class="ideas-grid">

      {featured && (
        <a class="idea-card featured reveal" href={`/posts/${featured.id}`}>
          <div class="idea-meta">
            <p class="featured-label">
              {featured.data.series
                ? `${featured.data.series} · ${t('card.part')} ${featured.data.seriesPart}`
                : t('card.featured')}
            </p>
            <h3 class="idea-title">{featured.data.title}</h3>
            <div class="idea-footer">
              <span class="idea-date">{formatDate(featured.data.date, lang)}</span>
              <span class="idea-arrow">→</span>
            </div>
          </div>
          <div class="idea-content">
            <p class="featured-abstract">{featured.data.description}</p>
          </div>
        </a>
      )}

      {rest.map(post => (
        <a class="idea-card reveal" href={`/posts/${post.id}`}>
          <p class="idea-tag">{post.data.topic}</p>
          <h3 class="idea-title">{post.data.title}</h3>
          <p class="idea-excerpt">{post.data.description}</p>
          <div class="idea-footer">
            <span class="idea-date">{formatDate(post.data.date, lang)}</span>
            <span class="idea-arrow">→</span>
          </div>
        </a>
      ))}

    </div>
  </section>

  <section id="connect">
    <div class="connect-inner">
      <div class="connect-text reveal">
        <p>If something here connects to a question you are working through —
        a structural parallel you have noticed, a foundation that seems
        shakier than assumed, a pattern recurring where it shouldn't — that
        is worth a conversation.</p>
        <p>The thinking is in progress and genuinely open to correction.</p>
      </div>
      <div class="connect-links reveal">
        <a class="connect-link" href="mailto:jorge.gonzalez@live.com">
          <div class="connect-link-label">
            <span class="connect-link-type">Email</span>
            <span class="connect-link-value">jorge.gonzalez@live.com</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
        <a class="connect-link" href="https://github.com/Jorge-Gonzalez" target="_blank" rel="noopener">
          <div class="connect-link-label">
            <span class="connect-link-type">GitHub</span>
            <span class="connect-link-value">github.com/Jorge-Gonzalez</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
        <a class="connect-link" href="https://www.linkedin.com/in/jorge-leonardo-gonzalez-b80b2b402" target="_blank" rel="noopener">
          <div class="connect-link-label">
            <span class="connect-link-type">LinkedIn</span>
            <span class="connect-link-value">jorge-leonardo-gonzalez</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero canvas ── */
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .hero-eyebrow,
  .hero-name,
  .hero-title,
  .hero-statement,
  .hero-scroll {
    position: relative;
    z-index: 1;
  }

  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow::before {
    content: "";
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .hero-name span {
    display: block;
    color: var(--accent);
    font-style: italic;
  }
  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }
  .hero-statement {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-style: italic;
    color: var(--text-muted);
    max-width: 640px;
    line-height: 1.5;
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: 2rem;
    writing-mode: vertical-rl;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hero-scroll::after {
    content: "";
    display: block;
    width: 1px;
    height: 3rem;
    background: var(--border);
  }

  /* ── Sections ── */
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 2rem;
    border-top: 1px solid var(--border-soft);
  }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
  }
  .section-number {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    flex-shrink: 0;
  }

  /* ── Ideas ── */
  .ideas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .idea-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    transition: border-color var(--transition), background var(--transition),
      transform var(--transition);
    cursor: pointer;
  }
  .idea-card:hover {
    border-color: var(--accent-dim);
    background: var(--bg-hover);
    transform: translateY(-2px);
  }
  .idea-card:hover .idea-arrow { color: var(--accent); }
  .idea-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .idea-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.25;
    color: var(--text);
    margin-bottom: 0.75rem;
    flex-grow: 1;
  }
  .idea-excerpt {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .idea-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .idea-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }
  .idea-arrow {
    color: var(--text-dim);
    transition: color var(--transition);
  }
  .idea-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .idea-card.featured .idea-title {
    font-size: 1.9rem;
    line-height: 1.15;
  }
  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .featured-abstract {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Connect ── */
  .connect-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .connect-text p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .connect-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .connect-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    transition: border-color var(--transition), background var(--transition);
  }
  .connect-link:hover {
    border-color: var(--accent-dim);
    background: var(--bg-hover);
  }
  .connect-link:hover .connect-link-arrow { color: var(--accent); }
  .connect-link-label {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .connect-link-type {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .connect-link-value {
    font-size: 0.95rem;
    color: var(--text);
  }
  .connect-link-arrow {
    color: var(--text-dim);
    transition: color var(--transition);
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-eyebrow   { animation: fadeUp 0.7s 0.1s ease both; }
  .hero-name      { animation: fadeUp 0.7s 0.2s ease both; }
  .hero-title     { animation: fadeUp 0.7s 0.32s ease both; }
  .hero-statement { animation: fadeUp 0.7s 0.44s ease both; }
  .hero-scroll    { animation: fadeUp 0.7s 0.6s ease both; }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  .hero-about-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }
  .hero-about-link:hover { color: var(--accent-dim); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 7rem 1.25rem 4rem; }
    section { padding: 4rem 1.25rem; }
    .connect-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .idea-card.featured { grid-template-columns: 1fr; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible')
    }),
    { threshold: 0.1 }
  )
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el))

  // Hero — Graph Game of Life with force-directed movement
  ;(function () {
    const canvas  = document.getElementById('heroCanvas')! as HTMLCanvasElement
    if (!canvas) return
    const ctx     = canvas.getContext('2d')!
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    let bg: string, fg: string, accent: string
    function readColors() {
      const s = getComputedStyle(document.documentElement)
      bg     = s.getPropertyValue('--bg').trim()
      fg     = s.getPropertyValue('--text').trim()
      accent = s.getPropertyValue('--accent').trim()
    }
    readColors()
    new MutationObserver(readColors).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme', 'class']
    })

    const N_TARGET   = 55
    const N_MAX      = 68
    const N_MIN      = 20
    const K          = 5
    const FADE       = 0.05
    const STEP_MS    = 500
    const PERTURB_MS = 8000
    const REPEL      = 3000
    const REST       = 130
    const REST_ALV   = 80
    const SPRING     = 0.012
    const DAMP       = 0.86
    const MAX_V      = 2.2
    const MARGIN     = 60
    const DEATH_STEPS = 7
    const P_SPAWN    = 0.4

    type Node = {
      x: number; y: number; vx: number; vy: number
      state: number; alpha: number; ripple: number; deadSteps: number
    }
    let nodes: Node[] = []
    let adj:   number[][] = []
    let edges: [number, number][] = []

    function rebuildConnections() {
      const n = nodes.length
      const adjSet = Array.from({ length: n }, () => new Set<number>())
      for (let i = 0; i < n; i++) {
        Array.from({ length: n }, (_, j) => j)
          .filter(j => j !== i)
          .sort((a, b) =>
            Math.hypot(nodes[a].x - nodes[i].x, nodes[a].y - nodes[i].y) -
            Math.hypot(nodes[b].x - nodes[i].x, nodes[b].y - nodes[i].y)
          )
          .slice(0, K)
          .forEach(j => { adjSet[i].add(j); adjSet[j].add(i) })
      }
      adj   = adjSet.map(s => [...s])
      edges = []
      for (let i = 0; i < n; i++)
        for (const j of adj[i])
          if (j > i) edges.push([i, j])
    }

    function build() {
      nodes = Array.from({ length: N_TARGET }, () => ({
        x:         Math.random() * canvas.width,
        y:         Math.random() * canvas.height,
        vx: 0,     vy: 0,
        state:     Math.random() < 0.32 ? 1 : 0,
        alpha:     0,
        ripple:    0,
        deadSteps: 0,
      }))
      rebuildConnections()
      for (const n of nodes) n.alpha = n.state
    }

    function resize() {
      canvas.width  = canvas.offsetWidth
      canvas.height = canvas.offsetHeight
      if (canvas.width > 0 && canvas.height > 0) build()
    }
    window.addEventListener('resize', resize)
    resize()

    function applyForces() {
      const N = nodes.length
      for (let i = 0; i < N; i++) {
        for (let j = i + 1; j < N; j++) {
          const dx = nodes[i].x - nodes[j].x
          const dy = nodes[i].y - nodes[j].y
          const d2 = Math.max(dx * dx + dy * dy, 1)
          const d  = Math.sqrt(d2)
          const f  = REPEL / d2
          const fx = (dx / d) * f;  const fy = (dy / d) * f
          nodes[i].vx += fx;  nodes[i].vy += fy
          nodes[j].vx -= fx;  nodes[j].vy -= fy
        }
      }
      for (const [a, b] of edges) {
        const dx   = nodes[b].x - nodes[a].x
        const dy   = nodes[b].y - nodes[a].y
        const d    = Math.hypot(dx, dy) || 0.1
        const both = nodes[a].state === 1 && nodes[b].state === 1
        const f    = SPRING * (d - (both ? REST_ALV : REST))
        const fx   = (dx / d) * f;  const fy = (dy / d) * f
        nodes[a].vx += fx;  nodes[a].vy += fy
        nodes[b].vx -= fx;  nodes[b].vy -= fy
      }
      for (const n of nodes) {
        n.vx *= DAMP;  n.vy *= DAMP
        n.vx = Math.max(-MAX_V, Math.min(MAX_V, n.vx))
        n.vy = Math.max(-MAX_V, Math.min(MAX_V, n.vy))
        if (n.x < MARGIN)                 n.vx += 0.4
        if (n.x > canvas.width - MARGIN)  n.vx -= 0.4
        if (n.y < MARGIN)                 n.vy += 0.4
        if (n.y > canvas.height - MARGIN) n.vy -= 0.4
        n.x += n.vx;  n.y += n.vy
      }
    }

    function checkLifecycle() {
      let changed = false
      for (let i = nodes.length - 1; i >= 0; i--) {
        if (nodes.length <= N_MIN) break
        if (nodes[i].deadSteps > DEATH_STEPS && nodes[i].alpha < 0.05) {
          nodes.splice(i, 1)
          changed = true
        }
      }
      const alive = nodes.filter(n => n.state === 1)
      if (nodes.length < N_MAX && Math.random() < P_SPAWN) {
        const parent = alive.length > 0
          ? alive[Math.floor(Math.random() * alive.length)]
          : nodes[Math.floor(Math.random() * nodes.length)]
        const angle = Math.random() * Math.PI * 2
        const dist  = 80 + Math.random() * 100
        nodes.push({
          x:         Math.max(MARGIN, Math.min(canvas.width  - MARGIN, parent.x + Math.cos(angle) * dist)),
          y:         Math.max(MARGIN, Math.min(canvas.height - MARGIN, parent.y + Math.sin(angle) * dist)),
          vx: 0,     vy: 0,
          state:     0,
          alpha:     0,
          ripple:    0,
          deadSteps: 0,
        })
        changed = true
      }
      if (nodes.length < N_MIN) {
        nodes.push({
          x: MARGIN + Math.random() * (canvas.width  - 2 * MARGIN),
          y: MARGIN + Math.random() * (canvas.height - 2 * MARGIN),
          vx: 0, vy: 0,
          state: Math.random() < 0.4 ? 1 : 0,
          alpha: 0, ripple: 0, deadSteps: 0,
        })
        changed = true
      }
      if (changed) rebuildConnections()
    }

    function step() {
      const next = nodes.map((node, i) => {
        const alive = adj[i].filter(j => nodes[j].state === 1).length
        return node.state === 1
          ? (alive >= 1 && alive <= 3 ? 1 : 0)
          : (alive === 2 || alive === 3 ? 1 : 0)
      })
      nodes.forEach((n, i) => {
        if (next[i] === 1 && n.state === 0) n.ripple = 1
        n.state     = next[i]
        n.deadSteps = n.state === 0 ? n.deadSteps + 1 : 0
      })
      checkLifecycle()
    }

    function perturb() {
      nodes.forEach(n => {
        if (Math.random() < 0.12) n.state = Math.random() < 0.38 ? 1 : 0
      })
    }

    function hexRgb(hex: string) {
      const h = hex.replace('#', '')
      return `${parseInt(h.slice(0,2),16)},${parseInt(h.slice(2,4),16)},${parseInt(h.slice(4,6),16)}`
    }

    let lastStep = 0, lastPerturb = 0

    function frame(now: number) {
      if (!canvas.width || !canvas.height) { requestAnimationFrame(frame); return }

      if (!reduced) applyForces()
      if (!reduced && now - lastStep > STEP_MS)       { step();    lastStep    = now }
      if (!reduced && now - lastPerturb > PERTURB_MS) { perturb(); lastPerturb = now }

      ctx.fillStyle = bg
      ctx.fillRect(0, 0, canvas.width, canvas.height)

      for (const n of nodes) {
        n.alpha  = n.state  > n.alpha  ? Math.min(1, n.alpha  + FADE) : Math.max(0, n.alpha  - FADE)
        n.ripple = n.ripple > 0        ? Math.max(0, n.ripple - 0.04) : 0
      }

      const acRgb = hexRgb(accent)
      const fgRgb = hexRgb(fg)

      for (const [a, b] of edges) {
        const avg = (nodes[a].alpha + nodes[b].alpha) / 2
        ctx.strokeStyle = avg > 0.1 ? `rgba(${acRgb},${avg * 0.35})` : `rgba(${fgRgb},0.06)`
        ctx.lineWidth   = avg > 0.1 ? 1.0 : 0.5
        ctx.beginPath()
        ctx.moveTo(nodes[a].x, nodes[a].y)
        ctx.lineTo(nodes[b].x, nodes[b].y)
        ctx.stroke()
      }

      for (const n of nodes) {
        if (n.ripple > 0) {
          ctx.strokeStyle = `rgba(${acRgb},${n.ripple * 0.45})`
          ctx.lineWidth   = 1
          ctx.beginPath()
          ctx.arc(n.x, n.y, 6 + (1 - n.ripple) * 20, 0, Math.PI * 2)
          ctx.stroke()
        }
        const a = n.alpha
        if (a > 0.04) {
          ctx.fillStyle = `rgba(${acRgb},${a * 0.85})`
          ctx.beginPath()
          ctx.arc(n.x, n.y, 2 + a * 3, 0, Math.PI * 2)
          ctx.fill()
        } else {
          ctx.fillStyle = `rgba(${fgRgb},0.1)`
          ctx.beginPath()
          ctx.arc(n.x, n.y, 2, 0, Math.PI * 2)
          ctx.fill()
        }
      }

      requestAnimationFrame(frame)
    }

    requestAnimationFrame(frame)
  })()
</script>
