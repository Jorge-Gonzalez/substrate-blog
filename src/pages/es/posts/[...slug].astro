---
import Base from '../../../layouts/Base.astro'
import { getCollection, render } from 'astro:content'
import { formatDate } from '../../../utils/formatDate'
import { useTranslations } from '../../../i18n/ui'

export async function getStaticPaths() {
  // Build routes from the English collection so every post always has a
  // Spanish URL, even if the translation is still a draft.
  const enPosts = await getCollection('postsEn')
  const esPosts = await getCollection('postsEs')

  const esMap = new Map(esPosts.map(p => [p.id, p]))

  const sorted = enPosts.filter(p => !p.id.includes('/')).sort((a, b) => {
    if (a.data.seriesPart && b.data.seriesPart) {
      return a.data.seriesPart - b.data.seriesPart
    }
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  })

  const esSorted = sorted.map(s => {
    const esS = esMap.get(s.id)
    return (esS && esS.data.status !== 'draft') ? esS : s
  })

  return sorted.map((enPost, index) => {
    const esPost    = esMap.get(enPost.id)
    const isDraft   = !esPost || esPost.data.status === 'draft'
    const activePost = isDraft ? enPost : esPost!

    return {
      params: { slug: enPost.id },
      props: {
        post:        activePost,
        enPost,
        isDraft,
        prev: index > 0 ? esSorted[index - 1] : null,
        next: index < esSorted.length - 1 ? esSorted[index + 1] : null,
      },
    }
  })
}

const lang = 'es'
const t    = useTranslations(lang)

const { post, isDraft, prev, next } = Astro.props
const { Content } = await render(post)
---

<Base title={post.data.title} description={post.data.description}>
  <article class="post">

    {isDraft && (
      <div class="translation-notice">
        <span>{t('post.translation_notice')}</span>
      </div>
    )}

    <header class="post-header">
      {post.data.series && (
        <p class="post-series">
          {post.data.series}
          {post.data.seriesPart && ` — ${t('post.part')} ${post.data.seriesPart}`}
        </p>
      )}
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span>{post.data.topic}</span>
        <span>{formatDate(post.data.date, lang)}</span>
        <span>{post.data.readingTime}</span>
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <section class="comments">
      <h2 class="comments-heading">{t('post.comments')}</h2>
      <div id="remark42"></div>
    </section>

    <footer class="post-footer">
      <div class="post-nav">
        {prev && (
          <a href={`/es/posts/${prev.id}`} class="post-nav-link prev">
            <span class="post-nav-label">{t('post.previous')}</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
        {next && (
          <a href={`/es/posts/${next.id}`} class="post-nav-link next">
            <span class="post-nav-label">{t('post.next')}</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
      <a href="/es#ideas" class="back-link">{t('post.back')}</a>
    </footer>

  </article>
</Base>

<script>
  function initRemark42() {
    const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'

    // @ts-ignore
    window.remark_config = {
      host:       'https://comments.substrate.lat',
      site_id:    'substrate',
      url:        window.location.href,
      theme:      theme,
      components: ['embed'],
      no_footer:  true,
    }

    const script = document.createElement('script')
    script.src   = 'https://comments.substrate.lat/web/embed.js'
    script.defer = true
    document.body.appendChild(script)

    const observer = new MutationObserver(() => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light'
      // @ts-ignore
      if (window.REMARK42) window.REMARK42.changeTheme(next)
    })
    observer.observe(document.documentElement, {
      attributes:      true,
      attributeFilter: ['data-theme'],
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRemark42)
  } else {
    initRemark42()
  }
</script>

