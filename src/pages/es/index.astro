---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { formatDate } from '../../utils/formatDate'
import { useTranslations } from '../../i18n/ui'

const lang = 'es'
const t    = useTranslations(lang)

const posts  = await getCollection('postsEs')
const sorted = posts.sort((a, b) => {
  if (a.data.seriesPart && b.data.seriesPart) {
    return a.data.seriesPart - b.data.seriesPart
  }
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
})
const featured = sorted[0]
const rest     = sorted.slice(1)
---

<Base title="Substrate" description="Notas sobre terreno común — diseño, matemáticas, filosofía.">

  <section class="hero" id="home">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-eyebrow">
      <span class="label">Substrate.lat</span>
    </div>
    <h1 class="hero-name">
      Substrate
    </h1>
    <p class="hero-title">Notas sobre terreno común</p>
    <p class="hero-statement">
      Las mismas estructuras subyacentes aparecen en campos que no tienen
      una razón obvia para compartirlas. Este sitio sigue esa observación
      — a través del diseño, las matemáticas y la filosofía. No
      conclusiones. Notas.
      <a href="/es/about" class="hero-about-link">Acerca de →</a>
    </p>
    <span class="hero-scroll">Bajar</span>
  </section>

  <section id="ideas">
    <div class="ideas-grid">

      {featured && (
        <a class="idea-card featured reveal" href={`/es/posts/${featured.id}`}>
          <div class="idea-meta">
            <p class="featured-label">
              {featured.data.series
                ? `${featured.data.series} · ${t('card.part')} ${featured.data.seriesPart}`
                : t('card.featured')}
            </p>
            <h3 class="idea-title">{featured.data.title}</h3>
            <div class="idea-footer">
              <span class="idea-date">{formatDate(featured.data.date, lang)}</span>
              <span class="idea-arrow">→</span>
            </div>
          </div>
          <div class="idea-content">
            <p class="featured-abstract">{featured.data.description}</p>
          </div>
        </a>
      )}

      {rest.map(post => (
        <a class="idea-card reveal" href={`/es/posts/${post.id}`}>
          <p class="idea-tag">{post.data.topic}</p>
          <h3 class="idea-title">{post.data.title}</h3>
          <p class="idea-excerpt">{post.data.description}</p>
          <div class="idea-footer">
            <span class="idea-date">{formatDate(post.data.date, lang)}</span>
            <span class="idea-arrow">→</span>
          </div>
        </a>
      ))}

    </div>
  </section>

  <section id="connect">
    <div class="connect-inner">
      <div class="connect-text reveal">
        <p>Si algo aquí conecta con una pregunta en la que estás trabajando
        — un paralelismo estructural que has notado, una base que parece
        más frágil de lo que se asume, un patrón que reaparece donde no
        debería — eso vale una conversación.</p>
        <p>El pensamiento está en progreso y genuinamente abierto a
        corrección.</p>
      </div>
      <div class="connect-links reveal">
        <a class="connect-link" href="mailto:jorge.gonzalez@live.com">
          <div class="connect-link-label">
            <span class="connect-link-type">Email</span>
            <span class="connect-link-value">jorge.gonzalez@live.com</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
        <a class="connect-link" href="https://github.com/Jorge-Gonzalez" target="_blank" rel="noopener">
          <div class="connect-link-label">
            <span class="connect-link-type">GitHub</span>
            <span class="connect-link-value">github.com/Jorge-Gonzalez</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
        <a class="connect-link" href="https://www.linkedin.com/in/jorge-leonardo-gonzalez-b80b2b402" target="_blank" rel="noopener">
          <div class="connect-link-label">
            <span class="connect-link-type">LinkedIn</span>
            <span class="connect-link-value">jorge-leonardo-gonzalez</span>
          </div>
          <span class="connect-link-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 8rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .hero-eyebrow,
  .hero-name,
  .hero-title,
  .hero-statement,
  .hero-scroll {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow::before {
    content: "";
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .hero-name span {
    display: block;
    color: var(--accent);
    font-style: italic;
  }
  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }
  .hero-statement {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-style: italic;
    color: var(--text-muted);
    max-width: 640px;
    line-height: 1.5;
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: 2rem;
    writing-mode: vertical-rl;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hero-scroll::after {
    content: "";
    display: block;
    width: 1px;
    height: 3rem;
    background: var(--border);
  }
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 2rem;
    border-top: 1px solid var(--border-soft);
  }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
  }
  .section-number {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    flex-shrink: 0;
  }
  .ideas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .idea-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    transition: border-color var(--transition), background var(--transition),
      transform var(--transition);
    cursor: pointer;
  }
  .idea-card:hover {
    border-color: var(--accent-dim);
    background: var(--bg-hover);
    transform: translateY(-2px);
  }
  .idea-card:hover .idea-arrow { color: var(--accent); }
  .idea-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .idea-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.25;
    color: var(--text);
    margin-bottom: 0.75rem;
    flex-grow: 1;
  }
  .idea-excerpt {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .idea-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .idea-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }
  .idea-arrow {
    color: var(--text-dim);
    transition: color var(--transition);
  }
  .idea-card.featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .idea-card.featured .idea-title {
    font-size: 1.9rem;
    line-height: 1.15;
  }
  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .featured-abstract {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .connect-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .connect-text p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .connect-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .connect-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    transition: border-color var(--transition), background var(--transition);
  }
  .connect-link:hover {
    border-color: var(--accent-dim);
    background: var(--bg-hover);
  }
  .connect-link:hover .connect-link-arrow { color: var(--accent); }
  .connect-link-label {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .connect-link-type {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .connect-link-value {
    font-size: 0.95rem;
    color: var(--text);
  }
  .connect-link-arrow {
    color: var(--text-dim);
    transition: color var(--transition);
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-eyebrow   { animation: fadeUp 0.7s 0.1s ease both; }
  .hero-name      { animation: fadeUp 0.7s 0.2s ease both; }
  .hero-title     { animation: fadeUp 0.7s 0.32s ease both; }
  .hero-statement { animation: fadeUp 0.7s 0.44s ease both; }
  .hero-scroll    { animation: fadeUp 0.7s 0.6s ease both; }
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }
  .hero-about-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }
  .hero-about-link:hover { color: var(--accent-dim); }
  @media (max-width: 768px) {
    .hero { padding: 7rem 1.25rem 4rem; }
    section { padding: 4rem 1.25rem; }
    .connect-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .idea-card.featured { grid-template-columns: 1fr; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible')
    }),
    { threshold: 0.1 }
  )
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el))

  ;(function () {
    const canvas = document.getElementById('heroCanvas')! as HTMLCanvasElement
    if (!canvas) return
    const ctx = canvas.getContext('2d')!
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    let bg: string, fg: string, accent: string
    function readColors() {
      const s = getComputedStyle(document.documentElement)
      bg     = s.getPropertyValue('--bg').trim()
      fg     = s.getPropertyValue('--text').trim()
      accent = s.getPropertyValue('--accent').trim()
    }
    readColors()
    new MutationObserver(readColors).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme', 'class']
    })

    const N    = 22
    const DIST = 160
    const SPD  = 0.28
    const nodes: { x: number; y: number; vx: number; vy: number }[] = []

    function resize() {
      canvas.width  = canvas.offsetWidth
      canvas.height = canvas.offsetHeight
      if (nodes.length === 0) {
        for (let i = 0; i < N; i++) {
          nodes.push({
            x:  Math.random() * canvas.width,
            y:  Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * SPD * 2,
            vy: (Math.random() - 0.5) * SPD * 2,
          })
        }
      }
    }
    window.addEventListener('resize', resize)
    resize()

    const paths: { a: number; b: number; born: number }[] = []
    let lastPath = 0
    const PATH_EVERY    = 2800
    const PATH_DURATION = 1800

    function rgb(hex: string) {
      const h = hex.replace('#', '')
      return [
        parseInt(h.slice(0, 2), 16),
        parseInt(h.slice(2, 4), 16),
        parseInt(h.slice(4, 6), 16),
      ].join(',')
    }

    function frame(now: number) {
      const w = canvas.width
      const h = canvas.height

      ctx.fillStyle = bg
      ctx.fillRect(0, 0, w, h)

      if (!reduced) {
        for (const n of nodes) {
          n.x += n.vx; n.y += n.vy
          if (n.x < 0)  { n.x  = 0; n.vx =  Math.abs(n.vx) }
          if (n.x > w)  { n.x  = w; n.vx = -Math.abs(n.vx) }
          if (n.y < 0)  { n.y  = 0; n.vy =  Math.abs(n.vy) }
          if (n.y > h)  { n.y  = h; n.vy = -Math.abs(n.vy) }
        }
      }

      const fgRgb = rgb(fg)
      const acRgb = rgb(accent)

      for (let i = 0; i < N; i++) {
        for (let j = i + 1; j < N; j++) {
          const d = Math.hypot(nodes[i].x - nodes[j].x, nodes[i].y - nodes[j].y)
          if (d < DIST) {
            ctx.strokeStyle = `rgba(${fgRgb},${(1 - d / DIST) * 0.13})`
            ctx.lineWidth   = 0.8
            ctx.beginPath()
            ctx.moveTo(nodes[i].x, nodes[i].y)
            ctx.lineTo(nodes[j].x, nodes[j].y)
            ctx.stroke()
          }
        }
      }

      for (let i = paths.length - 1; i >= 0; i--) {
        const p = paths[i]
        const t = (now - p.born) / PATH_DURATION
        if (t > 1) { paths.splice(i, 1); continue }
        const a = t < 0.2 ? t / 0.2 : 1 - (t - 0.2) / 0.8
        ctx.strokeStyle = `rgba(${acRgb},${a * 0.7})`
        ctx.lineWidth   = 1.5
        ctx.beginPath()
        ctx.moveTo(nodes[p.a].x, nodes[p.a].y)
        ctx.lineTo(nodes[p.b].x, nodes[p.b].y)
        ctx.stroke()
        ;[p.a, p.b].forEach(idx => {
          ctx.fillStyle = `rgba(${acRgb},${a})`
          ctx.beginPath()
          ctx.arc(nodes[idx].x, nodes[idx].y, 3.5, 0, Math.PI * 2)
          ctx.fill()
        })
      }

      if (!reduced && now - lastPath > PATH_EVERY) {
        const a = Math.floor(Math.random() * N)
        let b   = Math.floor(Math.random() * N)
        while (b === a) b = Math.floor(Math.random() * N)
        paths.push({ a, b, born: now })
        lastPath = now
      }

      for (const n of nodes) {
        ctx.fillStyle = `rgba(${fgRgb},0.22)`
        ctx.beginPath()
        ctx.arc(n.x, n.y, 2.5, 0, Math.PI * 2)
        ctx.fill()
      }

      requestAnimationFrame(frame)
    }

    requestAnimationFrame(frame)
  })()
</script>
