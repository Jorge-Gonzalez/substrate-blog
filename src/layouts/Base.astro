---
import '../styles/global.css'
import { getLangFromUrl, getPathWithoutLocale, useTranslations } from '../i18n/ui'

interface Props {
  title?:       string
  description?: string
}

const {
  title       = 'Substrate',
  description = 'Ideas one level below the obvious'
} = Astro.props

const lang    = getLangFromUrl(Astro.url)
const t       = useTranslations(lang)
const barePath = getPathWithoutLocale(Astro.url.pathname)
const enUrl   = barePath
const esUrl   = '/es' + (barePath === '/' ? '' : barePath)
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} — Substrate`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://substrate.lat${Astro.url.pathname}`} />
  <meta property="og:site_name" content="Substrate" />

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} — Substrate`} />
  <meta name="twitter:description" content={description} />

  <!-- Alternate language links -->
  <link rel="alternate" hreflang="en" href={`https://substrate.lat${enUrl}`} />
  <link rel="alternate" hreflang="es" href={`https://substrate.lat${esUrl}`} />
  <link rel="alternate" hreflang="x-default" href={`https://substrate.lat${enUrl}`} />

  <!-- Canonical -->
  <link rel="canonical" href={`https://substrate.lat${Astro.url.pathname}`} />

  <title>{title} — Substrate</title>

  <script defer src="https://cloud.umami.is/script.js" data-website-id="8605845f-006f-42c1-a094-46a4aa601e04"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <nav>
    <a class="nav-name" href={lang === 'es' ? '/es' : '/'}>Substrate<span class="dot">·</span></a>
    <div class="nav-right">
      <ul class="nav-links">
        <li><a href={lang === 'es' ? '/es/about' : '/about'}>{t('nav.about')}</a></li>
        <li><a href={lang === 'es' ? '/es#ideas' : '/#ideas'}>{t('nav.ideas')}</a></li>
        <li><a href={lang === 'es' ? '/es#connect' : '/#connect'}>{t('nav.connect')}</a></li>
      </ul>

      <div class="lang-switcher">
        <a href={enUrl} class:list={['lang-link', { active: lang === 'en' }]}>EN</a>
        <span class="lang-sep">·</span>
        <a href={esUrl} class:list={['lang-link', { active: lang === 'es' }]}>ES</a>
      </div>

      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <span id="themeIcon">☽</span>
        <span id="themeLabel" data-dark={t('theme.dark')} data-light={t('theme.light')}>{t('theme.dark')}</span>
      </button>
    </div>
  </nav>

  <slot />

  <footer>
    <span class="footer-name">Substrate.lat</span>
    <span class="footer-copy">© 2026 Jorge Gonzalez</span>
  </footer>

</body>
</html>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-soft);
  }

  .nav-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--text);
  }

  .dot {
    color: var(--accent);
    margin-left: 1px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .nav-links a:hover { color: var(--accent); }

  /* ── Language switcher ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
  }

  .lang-link {
    color: var(--text-dim);
    transition: color var(--transition);
    text-transform: uppercase;
  }

  .lang-link:hover      { color: var(--accent); }
  .lang-link.active     { color: var(--accent); }

  .lang-sep {
    color: var(--border);
    font-size: 0.5rem;
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 0.3rem 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: border-color var(--transition), color var(--transition);
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  footer {
    border-top: 1px solid var(--border-soft);
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
</style>

<script>
  const toggle = document.getElementById('themeToggle')
  const icon   = document.getElementById('themeIcon')
  const label  = document.getElementById('themeLabel')
  const html   = document.documentElement

  const saved      = localStorage.getItem('theme')
  const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches

  if (saved === 'dark' || (!saved && systemDark)) applyDark()

  toggle?.addEventListener('click', () => {
    if (html.dataset.theme === 'dark') {
      html.removeAttribute('data-theme')
      localStorage.setItem('theme', 'light')
      if (icon)  icon.textContent  = '☽'
      // restore translated label from data attribute
      if (label) label.textContent = label.dataset.dark ?? 'Dark'
    } else {
      applyDark()
      localStorage.setItem('theme', 'dark')
    }
  })

  function applyDark() {
    html.dataset.theme = 'dark'
    if (icon)  icon.textContent  = '○'
    if (label) label.textContent = label.dataset.light ?? 'Light'
  }
</script>
