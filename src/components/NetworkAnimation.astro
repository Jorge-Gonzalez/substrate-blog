<div class="animation-container">
  <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
  
  <div class="controls reveal" id="controls">
    <button class="controls-toggle" id="controlsToggle" aria-label="Toggle controls">
      <span class="controls-icon">⚙</span>
      <span class="controls-label">Parameters</span>
    </button>
    
    <div class="controls-panel">
      <div class="control-group">
        <label>
          Nodes: <span id="valNodes">55</span>
          <input type="range" id="rangeNodes" min="10" max="120" value="55" step="1" />
        </label>
      </div>
      <div class="control-group">
        <label>
          Repel: <span id="valRepel">3000</span>
          <input type="range" id="rangeRepel" min="500" max="8000" value="3000" step="100" />
        </label>
      </div>
      <div class="control-group">
        <label>
          Stiffness: <span id="valSpring">0.012</span>
          <input type="range" id="rangeSpring" min="0.001" max="0.040" value="0.012" step="0.001" />
        </label>
      </div>
      <div class="control-group">
        <label>
          Speed: <span id="valSpeed">500</span>ms
          <input type="range" id="rangeSpeed" min="100" max="2000" value="500" step="50" />
        </label>
      </div>
      <div class="control-group">
        <label>
          Gravity: <span id="valGravity">0.001</span>
          <input type="range" id="rangeGravity" min="0" max="0.005" value="0.001" step="0.0001" />
        </label>
      </div>
      <button class="controls-reset" id="controlsReset">Reset to Defaults</button>
    </div>
  </div>
</div>

<style>
  .animation-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .controls {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    z-index: 10;
    pointer-events: auto;
  }
  .controls-toggle {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 0.4rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: all var(--transition);
  }
  .controls-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .controls-panel {
    position: absolute;
    bottom: calc(100% + 1rem);
    left: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    width: 220px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    backdrop-filter: blur(10px);
  }
  .controls.open .controls-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .control-group {
    margin-bottom: 1rem;
  }
  .control-group label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .control-group label span {
    color: var(--accent);
    float: right;
  }
  .control-group input {
    width: 100%;
    margin-top: 0.5rem;
    cursor: pointer;
    accent-color: var(--accent);
  }
  .controls-reset {
    width: 100%;
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.5rem;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--transition);
  }
  .controls-reset:hover {
    border-color: var(--accent-dim);
    color: var(--accent);
    background: var(--bg-hover);
  }

  @media (max-width: 768px) {
    .controls {
      bottom: auto;
      top: 5rem;
      left: 1.25rem;
    }
    .controls-panel {
      bottom: auto;
      top: calc(100% + 0.5rem);
    }
    .controls-label {
      display: none;
    }
    .controls-toggle {
      padding: 0.4rem;
      width: 2rem;
      height: 2rem;
      justify-content: center;
    }
  }
</style>

<script>
  // Hero — Graph Game of Life with force-directed movement
  ;(function () {
    const canvas  = document.getElementById('heroCanvas')! as HTMLCanvasElement
    if (!canvas) return
    const ctx     = canvas.getContext('2d')!
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    let bg: string, fg: string, accent: string
    function readColors() {
      const s = getComputedStyle(document.documentElement)
      bg     = s.getPropertyValue('--bg').trim()
      fg     = s.getPropertyValue('--text').trim()
      accent = s.getPropertyValue('--accent').trim()
    }
    readColors()
    new MutationObserver(readColors).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme', 'class']
    })

    // --- Dynamic Parameters ---
    const DEFAULTS = {
      nodes: 55,
      repel: 3000,
      spring: 0.012,
      speed: 500,
      gravity: 0.001
    }

    let N_TARGET   = DEFAULTS.nodes
    let N_MAX      = 68
    let N_MIN      = 20
    let REPEL      = DEFAULTS.repel
    let SPRING     = DEFAULTS.spring
    let STEP_MS    = DEFAULTS.speed
    let GRAVITY    = DEFAULTS.gravity
    
    const MARGIN     = 100
    const K          = 5
    const FADE       = 0.05
    const PERTURB_MS = 8000
    const REST       = 130
    const REST_ALV   = 80
    const DAMP       = 0.86
    const MAX_V      = 2.2
    const DEATH_STEPS = 7
    const P_SPAWN    = 0.4

    function updateLimits() {
      N_MAX = Math.floor(N_TARGET * 1.25)
      N_MIN = Math.floor(N_TARGET * 0.4)
    }

    // --- UI Logic ---
    const controls = document.getElementById('controls')
    const toggle = document.getElementById('controlsToggle')
    const resetBtn = document.getElementById('controlsReset')
    
    toggle?.addEventListener('click', () => controls?.classList.toggle('open'))

    const inputs: Record<string, HTMLInputElement> = {
      nodes: document.getElementById('rangeNodes') as HTMLInputElement,
      repel: document.getElementById('rangeRepel') as HTMLInputElement,
      spring: document.getElementById('rangeSpring') as HTMLInputElement,
      speed: document.getElementById('rangeSpeed') as HTMLInputElement,
      gravity: document.getElementById('rangeGravity') as HTMLInputElement
    }
    const displays: Record<string, HTMLElement> = {
      nodes: document.getElementById('valNodes')!,
      repel: document.getElementById('valRepel')!,
      spring: document.getElementById('valSpring')!,
      speed: document.getElementById('valSpeed')!,
      gravity: document.getElementById('valGravity')!
    }

    const updateUI = () => {
      inputs.nodes.value = N_TARGET.toString()
      inputs.repel.value = REPEL.toString()
      inputs.spring.value = SPRING.toString()
      inputs.speed.value = STEP_MS.toString()
      inputs.gravity.value = GRAVITY.toString()
      
      displays.nodes.textContent = N_TARGET.toString()
      displays.repel.textContent = REPEL.toString()
      displays.spring.textContent = SPRING.toString()
      displays.speed.textContent = STEP_MS.toString()
      displays.gravity.textContent = GRAVITY.toString()
    }

    inputs.nodes.addEventListener('input', () => { 
      N_TARGET = parseFloat(inputs.nodes.value)
      displays.nodes.textContent = inputs.nodes.value
      updateLimits()
      checkLifecycle() // Immediate adjustment
    })
    inputs.repel.addEventListener('input', () => { REPEL = parseFloat(inputs.repel.value); displays.repel.textContent = inputs.repel.value })
    inputs.spring.addEventListener('input', () => { SPRING = parseFloat(inputs.spring.value); displays.spring.textContent = inputs.spring.value })
    inputs.speed.addEventListener('input', () => { STEP_MS = parseFloat(inputs.speed.value); displays.speed.textContent = inputs.speed.value })
    inputs.gravity.addEventListener('input', () => { GRAVITY = parseFloat(inputs.gravity.value); displays.gravity.textContent = inputs.gravity.value })

    resetBtn?.addEventListener('click', () => {
      N_TARGET = DEFAULTS.nodes
      REPEL = DEFAULTS.repel
      SPRING = DEFAULTS.spring
      STEP_MS = DEFAULTS.speed
      GRAVITY = DEFAULTS.gravity
      updateLimits()
      updateUI()
    })

    updateLimits()
    updateUI()

    // --- Simulation ---

    type Node = {
      x: number; y: number; vx: number; vy: number
      state: number; alpha: number; ripple: number; deadSteps: number
      targetState: number; stateDelay: number
    }
    let nodes: Node[] = []
    let adj:   number[][] = []
    let edges: [number, number][] = []

    function rebuildConnections() {
      const n = nodes.length
      const adjSet = Array.from({ length: n }, () => new Set<number>())
      for (let i = 0; i < n; i++) {
        Array.from({ length: n }, (_, j) => j)
          .filter(j => j !== i)
          .sort((a, b) =>
            Math.hypot(nodes[a].x - nodes[i].x, nodes[a].y - nodes[i].y) -
            Math.hypot(nodes[b].x - nodes[i].x, nodes[b].y - nodes[i].y)
          )
          .slice(0, K)
          .forEach(j => { adjSet[i].add(j); adjSet[j].add(i) })
      }
      adj   = adjSet.map(s => [...s])
      edges = []
      for (let i = 0; i < n; i++)
        for (const j of adj[i])
          if (j > i) edges.push([i, j])
    }

    function build() {
      nodes = Array.from({ length: N_TARGET }, () => {
        const s = Math.random() < 0.32 ? 1 : 0
        return {
          x:         Math.random() * canvas.width,
          y:         Math.random() * canvas.height,
          vx: 0,     vy: 0,
          state:     s,
          targetState: s,
          stateDelay: 0,
          alpha:     0,
          ripple:    0,
          deadSteps: 0,
        }
      })
      rebuildConnections()
      for (const n of nodes) n.alpha = n.state
    }

    function resize() {
      canvas.width  = canvas.offsetWidth
      canvas.height = canvas.offsetHeight
      if (canvas.width > 0 && canvas.height > 0) build()
    }
    window.addEventListener('resize', resize)
    resize()

    function applyForces() {
      const N = nodes.length
      for (let i = 0; i < N; i++) {
        for (let j = i + 1; j < N; j++) {
          const dx = nodes[i].x - nodes[j].x
          const dy = nodes[i].y - nodes[j].y
          const d2 = Math.max(dx * dx + dy * dy, 1)
          const d  = Math.sqrt(d2)
          const f  = REPEL / d2
          const fx = (dx / d) * f;  const fy = (dy / d) * f
          nodes[i].vx += fx;  nodes[i].vy += fy
          nodes[j].vx -= fx;  nodes[j].vy -= fy
        }
      }
      for (const [a, b] of edges) {
        const dx   = nodes[b].x - nodes[a].x
        const dy   = nodes[b].y - nodes[a].y
        const d    = Math.hypot(dx, dy) || 0.1
        const both = nodes[a].state === 1 && nodes[b].state === 1
        const f    = SPRING * (d - (both ? REST_ALV : REST))
        const fx   = (dx / d) * f;  const fy = (dy / d) * f
        nodes[a].vx += fx;  nodes[a].vy += fy
        nodes[b].vx -= fx;  nodes[b].vy -= fy
      }
      const centerX = canvas.width / 2
      const centerY = canvas.height / 2

      for (const n of nodes) {
        // Subtle central gravity
        n.vx += (centerX - n.x) * GRAVITY
        n.vy += (centerY - n.y) * GRAVITY

        // Damping and velocity clamping
        n.vx *= DAMP;  n.vy *= DAMP
        n.vx = Math.max(-MAX_V, Math.min(MAX_V, n.vx))
        n.vy = Math.max(-MAX_V, Math.min(MAX_V, n.vy))

        // Exponential boundary push
        if (n.x < MARGIN) n.vx += Math.pow((MARGIN - n.x) / MARGIN, 2) * 1.5
        if (n.x > canvas.width - MARGIN) n.vx -= Math.pow((n.x - (canvas.width - MARGIN)) / MARGIN, 2) * 1.5
        if (n.y < MARGIN) n.vy += Math.pow((MARGIN - n.y) / MARGIN, 2) * 1.5
        if (n.y > canvas.height - MARGIN) n.vy -= Math.pow((n.y - (canvas.height - MARGIN)) / MARGIN, 2) * 1.5

        n.x += n.vx;  n.y += n.vy

        // Hard boundary clamp
        n.x = Math.max(2, Math.min(canvas.width - 2, n.x))
        n.y = Math.max(2, Math.min(canvas.height - 2, n.y))
      }
    }

    function checkLifecycle() {
      let changed = false
      
      // Aggressive removal if over N_MAX
      while (nodes.length > N_MAX) {
        // Find the "weakest" node to remove:
        // 1. Prefer nodes that are already state 0
        // 2. Among those, or if all are state 1, find the one with lowest alpha
        let weakestIdx = -1
        let minAlpha = 2
        
        for (let i = 0; i < nodes.length; i++) {
          const score = nodes[i].state + nodes[i].alpha
          if (score < minAlpha) {
            minAlpha = score
            weakestIdx = i
          }
        }
        
        if (weakestIdx !== -1) {
          nodes.splice(weakestIdx, 1)
          changed = true
        } else {
          break
        }
      }

      // Standard removal for naturally dying nodes
      for (let i = nodes.length - 1; i >= 0; i--) {
        if (nodes.length <= N_MIN) break
        if (nodes[i].deadSteps > DEATH_STEPS && nodes[i].alpha < 0.05) {
          nodes.splice(i, 1)
          changed = true
        }
      }
      
      const alive = nodes.filter(n => n.state === 1)
      if (nodes.length < N_MAX && Math.random() < P_SPAWN) {
        const parent = alive.length > 0
          ? alive[Math.floor(Math.random() * alive.length)]
          : nodes[Math.floor(Math.random() * nodes.length)]
        const angle = Math.random() * Math.PI * 2
        const dist  = 80 + Math.random() * 100
        nodes.push({
          x:         Math.max(MARGIN, Math.min(canvas.width  - MARGIN, parent.x + Math.cos(angle) * dist)),
          y:         Math.max(MARGIN, Math.min(canvas.height - MARGIN, parent.y + Math.sin(angle) * dist)),
          vx: 0,     vy: 0,
          state:     0,
          targetState: 0,
          stateDelay: 0,
          alpha:     0,
          ripple:    0,
          deadSteps: 0,
        })
        changed = true
      }
      if (nodes.length < N_MIN) {
        const s = Math.random() < 0.4 ? 1 : 0
        nodes.push({
          x: MARGIN + Math.random() * (canvas.width  - 2 * MARGIN),
          y: MARGIN + Math.random() * (canvas.height - 2 * MARGIN),
          vx: 0, vy: 0,
          state: s,
          targetState: s,
          stateDelay: 0,
          alpha: 0, ripple: 0, deadSteps: 0,
        })
        changed = true
      }
      if (changed) rebuildConnections()
    }

    function step() {
      const next = nodes.map((node, i) => {
        const alive = adj[i].filter(j => nodes[j].state === 1).length
        return node.state === 1
          ? (alive >= 1 && alive <= 3 ? 1 : 0)
          : (alive === 2 || alive === 3 ? 1 : 0)
      })
      nodes.forEach((n, i) => {
        if (next[i] !== n.state) {
          n.targetState = next[i]
          n.stateDelay  = Math.random() * STEP_MS
        } else {
          n.targetState = n.state
          n.stateDelay  = 0
        }
        n.deadSteps = n.state === 0 ? n.deadSteps + 1 : 0
      })
      checkLifecycle()
    }

    function perturb() {
      nodes.forEach(n => {
        if (Math.random() < 0.12) {
          n.targetState = Math.random() < 0.38 ? 1 : 0
          n.stateDelay  = Math.random() * STEP_MS
        }
      })
    }

    function hexRgb(hex: string) {
      const h = hex.replace('#', '')
      return `${parseInt(h.slice(0,2),16)},${parseInt(h.slice(2,4),16)},${parseInt(h.slice(4,6),16)}`
    }

    let lastStep = 0, lastPerturb = 0, lastFrame = 0

    function frame(now: number) {
      if (!canvas.width || !canvas.height) { requestAnimationFrame(frame); return }
      const dt = now - lastFrame
      lastFrame = now

      if (!reduced) applyForces()
      if (!reduced && now - lastStep > STEP_MS)       { step();    lastStep    = now }
      if (!reduced && now - lastPerturb > PERTURB_MS) { perturb(); lastPerturb = now }

      ctx.fillStyle = bg
      ctx.fillRect(0, 0, canvas.width, canvas.height)

      for (const n of nodes) {
        if (n.stateDelay > 0) {
          n.stateDelay -= dt
          if (n.stateDelay <= 0) {
            if (n.targetState === 1 && n.state === 0) n.ripple = 1
            n.state = n.targetState
          }
        }
        n.alpha  = n.state  > n.alpha  ? Math.min(1, n.alpha  + FADE) : Math.max(0, n.alpha  - FADE)
        n.ripple = n.ripple > 0        ? Math.max(0, n.ripple - 0.04) : 0
      }

      const acRgb = hexRgb(accent)
      const fgRgb = hexRgb(fg)

      for (const [a, b] of edges) {
        const avg = (nodes[a].alpha + nodes[b].alpha) / 2
        ctx.strokeStyle = avg > 0.1 ? `rgba(${acRgb},${avg * 0.35})` : `rgba(${fgRgb},0.06)`
        ctx.lineWidth   = avg > 0.1 ? 0.5 : 0.25
        ctx.beginPath()
        ctx.moveTo(nodes[a].x, nodes[a].y)
        ctx.lineTo(nodes[b].x, nodes[b].y)
        ctx.stroke()
      }

      for (const n of nodes) {
        if (n.ripple > 0) {
          ctx.strokeStyle = `rgba(${acRgb},${n.ripple * 0.45})`
          ctx.lineWidth   = 1
          ctx.beginPath()
          ctx.arc(n.x, n.y, 3 + (1 - n.ripple) * 10, 0, Math.PI * 2)
          ctx.stroke()
        }
        const a = n.alpha
        if (a > 0.04) {
          ctx.fillStyle = `rgba(${acRgb},${a * 0.85})`
          ctx.beginPath()
          ctx.arc(n.x, n.y, 1 + a * 2.5, 0, Math.PI * 2)
          ctx.fill()
        } else {
          ctx.fillStyle = `rgba(${fgRgb},0.1)`
          ctx.beginPath()
          ctx.arc(n.x, n.y, 1, 0, Math.PI * 2)
          ctx.fill()
        }
      }

      requestAnimationFrame(frame)
    }

    requestAnimationFrame(frame)
  })()
</script>
